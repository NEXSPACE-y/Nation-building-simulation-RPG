; Stage B Godot + C# causal-system validation project.
; Fixture content is temporary and loaded from ../data.
config_version=5

[application]

config/name="Nation Simulation Stage B"
run/main_scene="res://Main.tscn"

[display]

window/size/viewport_width=960
window/size/viewport_height=540

[dotnet]

project/assembly_name="NationSimulation.StageB"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.04, 0.05, 0.07, 1)
